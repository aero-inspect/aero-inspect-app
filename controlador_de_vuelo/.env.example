# MQTT broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USE_TLS=false
MQTT_TLS_CA_CERT=
MQTT_TLS_CLIENT_CERT=
MQTT_TLS_CLIENT_KEY=
MQTT_USERNAME=
MQTT_PASSWORD=

# Identidad del dron (namespace de tópicos MQTT = Dron.mqttClientId)
DRONE_ID=dron-x500-01

# Conexión MAVLink: udp://:14540 contra el simulador SITL, serial:///dev/ttyAMA0:921600 en hardware real
MAVLINK_CONNECTION=udp://:14540

# mavsdk_server: embedded (autospawn del binario incluido en el wheel) o external (proceso propio)
MAVSDK_SERVER_MODE=embedded
MAVSDK_SERVER_HOST=localhost
MAVSDK_SERVER_PORT=50051

TELEMETRY_PUBLISH_RATE_HZ=1.0
LOG_LEVEL=INFO
